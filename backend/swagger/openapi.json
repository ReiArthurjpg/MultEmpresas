{
  "openapi": "3.0.3",
  "info": {"title": "MultEmpresas SaaS API", "version": "1.0.0", "description": "API REST multiempresa com Clean Architecture, JWT, refresh token, TOTP, auditoria e CRUDs administrativos."},
  "servers": [{"url": "http://localhost:8010"}],
  "components": {
    "securitySchemes": {"bearerAuth": {"type": "http", "scheme": "bearer", "bearerFormat": "JWT"}},
    "schemas": {
      "LoginRequest": {"type": "object", "required": ["email", "password"], "properties": {"email": {"type": "string", "example": "master@system.local"}, "password": {"type": "string", "example": "Master@123"}, "totp_code": {"type": "string", "example": "123456"}}},
      "Plan": {"type": "object", "properties": {"name": {"type": "string"}, "description": {"type": "string"}, "price": {"type": "number"}, "active": {"type": "boolean"}, "permissions": {"type": "array", "items": {"type": "string"}}}},
      "Company": {"type": "object", "properties": {"company_name": {"type": "string"}, "trade_name": {"type": "string"}, "cnpj": {"type": "string"}, "email": {"type": "string"}, "phone": {"type": "string"}, "address": {"type": "string"}, "city": {"type": "string"}, "state": {"type": "string"}, "zip_code": {"type": "string"}, "plan_id": {"type": "integer"}, "active": {"type": "boolean"}}},
      "User": {"type": "object", "properties": {"company_id": {"type": "integer", "nullable": true}, "name": {"type": "string"}, "email": {"type": "string"}, "password": {"type": "string"}, "role": {"type": "string", "enum": ["MASTER", "ADMIN", "OPERATOR"]}, "active": {"type": "boolean"}}}
    }
  },
  "paths": {
    "/": {"get": {"summary": "Health check", "responses": {"200": {"description": "API ativa"}}}},
    "/auth/login": {"post": {"summary": "Login com email, senha e TOTP quando obrigatório", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/LoginRequest"}}}}, "responses": {"200": {"description": "Tokens e dados do usuário"}}}},
    "/auth/refresh": {"post": {"summary": "Renova access token", "requestBody": {"content": {"application/json": {"schema": {"type": "object", "properties": {"refresh_token": {"type": "string"}}}}}}, "responses": {"200": {"description": "Novo access token"}}}},
    "/auth/logout": {"post": {"security": [{"bearerAuth": []}], "summary": "Revoga refresh tokens do usuário", "responses": {"200": {"description": "Logout"}}}},
    "/auth/2fa/setup": {"post": {"security": [{"bearerAuth": []}], "summary": "Gera segredo TOTP e URL QRCode", "responses": {"200": {"description": "Segredo gerado"}}}},
    "/auth/2fa/verify": {"post": {"security": [{"bearerAuth": []}], "summary": "Valida código TOTP", "responses": {"200": {"description": "Validação"}}}},
    "/auth/2fa/enable": {"post": {"security": [{"bearerAuth": []}], "summary": "Habilita 2FA", "responses": {"200": {"description": "2FA habilitado"}}}},
    "/auth/2fa/disable": {"post": {"security": [{"bearerAuth": []}], "summary": "Desabilita 2FA para operadores", "responses": {"200": {"description": "2FA desabilitado"}}}},
    "/plans": {"get": {"security": [{"bearerAuth": []}], "summary": "Lista planos", "responses": {"200": {"description": "Lista"}}}, "post": {"security": [{"bearerAuth": []}], "summary": "Cria plano", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/Plan"}}}}, "responses": {"200": {"description": "Criado"}}}},
    "/plans/{id}": {"get": {"security": [{"bearerAuth": []}], "summary": "Detalha plano", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Detalhe"}}}, "put": {"security": [{"bearerAuth": []}], "summary": "Atualiza plano", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Atualizado"}}}, "delete": {"security": [{"bearerAuth": []}], "summary": "Remove plano", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Removido"}}}},
    "/companies": {"get": {"security": [{"bearerAuth": []}], "summary": "Lista empresas com isolamento por tenant", "responses": {"200": {"description": "Lista"}}}, "post": {"security": [{"bearerAuth": []}], "summary": "Cria empresa", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/Company"}}}}, "responses": {"200": {"description": "Criada"}}}},
    "/companies/{id}": {"get": {"security": [{"bearerAuth": []}], "summary": "Detalha empresa", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Detalhe"}}}, "put": {"security": [{"bearerAuth": []}], "summary": "Atualiza empresa", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Atualizada"}}}, "delete": {"security": [{"bearerAuth": []}], "summary": "Remove empresa", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Removida"}}}},
    "/companies/cnpj/{cnpj}": {"get": {"security": [{"bearerAuth": []}], "summary": "Consulta CNPJ em API pública e valida situação ativa", "parameters": [{"name": "cnpj", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Dados públicos"}}}},
    "/companies/{id}/logo": {"post": {"security": [{"bearerAuth": []}], "summary": "Upload de logo JPG, PNG ou WEBP", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "requestBody": {"content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"logo": {"type": "string", "format": "binary"}}}}}}, "responses": {"200": {"description": "Logo salva"}}}},
    "/users": {"get": {"security": [{"bearerAuth": []}], "summary": "Lista usuários com isolamento por tenant", "responses": {"200": {"description": "Lista"}}}, "post": {"security": [{"bearerAuth": []}], "summary": "Cria usuário", "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/User"}}}}, "responses": {"200": {"description": "Criado"}}}},
    "/users/{id}": {"get": {"security": [{"bearerAuth": []}], "summary": "Detalha usuário", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Detalhe"}}}, "put": {"security": [{"bearerAuth": []}], "summary": "Atualiza usuário", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Atualizado"}}}, "delete": {"security": [{"bearerAuth": []}], "summary": "Remove usuário", "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}], "responses": {"200": {"description": "Removido"}}}},
    "/audit-logs": {"get": {"security": [{"bearerAuth": []}], "summary": "Lista logs de auditoria respeitando tenant", "responses": {"200": {"description": "Logs"}}}}
  }
}
