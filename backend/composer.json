{
  "name": "multempresas/backend",
  "description": "API REST SaaS multiempresa em PHP 8.3 com MySQL, JWT, TOTP e Swagger.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-fileinfo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "migrate": "php src/Infrastructure/Console/migrate.php",
    "seed": "php src/Infrastructure/Console/seed.php",
    "test": "php tests/smoke.php"
  },
  "license": "proprietary"
}
