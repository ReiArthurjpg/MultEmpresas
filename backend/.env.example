APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8010
APP_KEY=change-me-to-a-32-char-random-secret

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=multempresas
DB_USERNAME=multempresas
DB_PASSWORD=multempresas_secret
MYSQL_ROOT_PASSWORD=root_secret

JWT_SECRET=change-me-super-secret-jwt-key
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=30d
LOGIN_RATE_LIMIT=12
LOGIN_BLOCK_SECONDS=900
TOTP_ISSUER=MultEmpresas
UPLOAD_MAX_BYTES=2097152
CNPJ_API_URL=https://brasilapi.com.br/api/cnpj/v1
